{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": ["DATABASE_URL", "SESSION_PEPPER", "TOKEN_PEPPER", "APP_BASE_URL", "SMTP_HOST", "SMTP_PORT", "SMTP_FROM_EMAIL", "NODE_ENV"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:integration": {
      "cache": false
    },
    "test:e2e": {
      "cache": false
    },
    "test:coverage": {
      "outputs": ["coverage/**"]
    }
  }
}
