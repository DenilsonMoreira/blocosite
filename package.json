{
  "name": "blocosite",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "dev": "turbo dev --parallel",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:integration": "turbo test:integration",
    "test:e2e": "turbo test:e2e",
    "test:coverage": "turbo test:coverage",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "ci": "pnpm check && pnpm test:integration && pnpm build",
    "db:generate": "pnpm --filter @blocosite/database db:generate",
    "db:migrate": "pnpm --filter @blocosite/database db:migrate",
    "db:seed": "pnpm --filter @blocosite/database db:seed"
  },
  "devDependencies": {
    "@blocosite/eslint-config": "workspace:*",
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "turbo": "^2.5.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.49.0"
  }
}
