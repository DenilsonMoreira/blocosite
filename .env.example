# Ambiente
NODE_ENV=development
LOG_LEVEL=debug

# URLs locais
APP_BASE_URL=http://app.localhost
API_BASE_URL=http://api.localhost
API_HOST=0.0.0.0
API_PORT=3333
ADMIN_PORT=3000
API_HOST_PORT=3333
SITES_PORT=3001
SITES_BASE_DOMAIN=localhost
MEDIA_BASE_URL=http://localhost:9000/blocosite-media
COOKIE_DOMAIN=.localhost

# Banco
POSTGRES_DB=blocosite
POSTGRES_USER=blocosite
POSTGRES_PASSWORD=change-me-local
POSTGRES_PORT=5433
DATABASE_URL=postgresql://blocosite:change-me-local@localhost:5433/blocosite?schema=public
TEST_DATABASE_URL=postgresql://blocosite:change-me-local@localhost:5433/blocosite_test?schema=public

# Sessão e tokens — gerar valores fortes fora do desenvolvimento
SESSION_PEPPER=replace-with-at-least-32-random-bytes
TOKEN_PEPPER=replace-with-at-least-32-random-bytes
APP_DATA_ENCRYPTION_KEY=replace-with-base64-32-byte-key
INTERNAL_SERVICE_SECRET=replace-with-at-least-32-random-bytes

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=blocosite-media
S3_ACCESS_KEY_ID=blocosite
S3_SECRET_ACCESS_KEY=change-me-local
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://localhost:9000/blocosite-media

# MinIO local
MINIO_ROOT_USER=blocosite
MINIO_ROOT_PASSWORD=change-me-local

# SMTP / Mailpit
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=BlocoSite
SMTP_FROM_EMAIL=no-reply@blocosite.local

# Turnstile opcional
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Caddy interno
CADDY_ASK_SECRET=replace-with-at-least-32-random-bytes

# Limites padrão
DEFAULT_MAX_SITES=3
DEFAULT_MAX_PAGES=25
DEFAULT_MAX_POSTS=200
DEFAULT_MAX_MEDIA_BYTES=1073741824
DEFAULT_MAX_RELEASES=20
DEFAULT_MAX_MEMBERS=5
DEFAULT_MAX_DOMAINS=5

# Upload
MAX_UPLOAD_BYTES=10485760
MAX_IMAGE_MEGAPIXELS=40

# Criptografia / privacidade
IP_HASH_PEPPER=replace-with-at-least-32-random-bytes
FORM_SUBMISSION_RETENTION_DAYS=365
AUDIT_LOG_RETENTION_DAYS=730
